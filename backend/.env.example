# Copy this file to .env and fill in real values.
# NEVER commit .env, and never paste real secrets into code, chat, or this file.
# .env is git-ignored; this .example carries placeholders only.

PORT=3000

# ── Razorpay ──  Dashboard → Settings → API Keys. Use TEST keys in development.
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ── Session signing ──  secret used to HMAC-sign login cookies.
# Generate a strong random value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_long_random_hex_string_here

# ── Google OAuth ──  Google Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
